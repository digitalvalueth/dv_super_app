{
  "functions": {
    "source": "functions",
    "codebase": "fittbsa",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log"
    ]
  },
  "firestore": [
    {
      "rules": "firestore.rules",
      "indexes": "firestore.indexes.json",
      "database": "fittsuperapp-dev"
    },
    {
      "rules": "firestore.rules",
      "indexes": "firestore.indexes.json",
      "database": "fittsuperapp-prod"
    }
  ],
  "storage": [
    {
      "bucket": "fittbsa-app-sandbox",
      "rules": "storage.rules"
    },
    {
      "bucket": "fittbsa-app-prod",
      "rules": "storage.rules"
    }
  ]
}
